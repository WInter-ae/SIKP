# Base URL backend SIKP (BFF)
VITE_SIKP_API_BASE_URL=http://localhost:3000

# Redirect URI callback frontend (dipakai saat /api/auth/prepare dan /api/auth/callback)
VITE_SSO_REDIRECT_URI=http://localhost:5173/callback

# URL manajemen profil di SSO (SIKP profile read-only)
VITE_SSO_PROFILE_URL=https://sso.unsri.ac.id/profile

# URL manajemen e-signature di SSO (SIKP signature read-only)
VITE_SSO_PROFILE_SIGNATURE_URL=https://sso.unsri.ac.id/profile/signature

# Backward compatibility (legacy env used by existing service calls)
VITE_API_URL=http://localhost:3000
VITE_APP_AUTH_URL=http://localhost:3000
VITE_API_BASE_URL=http://localhost:3000
